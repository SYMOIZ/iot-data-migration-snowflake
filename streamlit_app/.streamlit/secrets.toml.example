# Template only - no secrets in here. Copy to secrets.toml on the host that
# runs the app and it will not be committed (see .gitignore). The private
# key itself lives only on disk on the host (fetched from AWS Secrets
# Manager iot-hackathon/snowflake/streamlit-key at deploy time) and is
# never stored in this repo or in this file.

[snowflake]
account = "<SNOWFLAKE_ACCOUNT>"
user = "STREAMLIT_USER"
role = "STREAMLIT_ROLE"
warehouse = "IOT_INGEST_WH"
database = "IOT_PLATFORM"
# dbt's default schema-naming behavior concatenates the connection's default
# schema (BRONZE, from dbt/profiles.yml) with each model's custom +schema
# config, so the Gold layer actually lives in BRONZE_GOLD, not GOLD. See
# docs/operations/troubleshooting.md for detail.
schema = "BRONZE_GOLD"
private_key_path = "/opt/streamlit/keys/rsa_key.p8"
